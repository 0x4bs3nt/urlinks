# urlinks development environment - direnv configuration
#
# This file automatically activates the Nix development shell when you
# enter the project directory.
#
# Requirements:
# - direnv (https://direnv.net/)
# - nix-direnv (https://github.com/nix-community/nix-direnv)
#
# Setup:
# 1. Install direnv and hook it into your shell
# 2. Run: direnv allow
# 3. The Nix shell will activate automatically

# Use nix-direnv for faster shell activation (cached)
if ! has nix_direnv_version || ! nix_direnv_version 3.0.4; then
  source_url "https://raw.githubusercontent.com/nix-community/nix-direnv/3.0.4/direnvrc" \
    "sha256-DzlYZ33mWF/Gs8DDeyjr8mnVmQGx7ASYqA5WlxwvBG4="
fi

# Watch for changes in flake files
watch_file flake.nix
watch_file flake.lock

# Activate the Nix flake development shell
# --impure allows access to system state (needed for some operations)
use flake . --impure

# Load local environment overrides if present
# Create .env.local for personal settings (git-ignored)
dotenv_if_exists .env.local
