# Production Deployment Configuration
# Copy this file to .env and edit all values before deploying
# All configuration is in this single file

# ============================================================================
# DEPLOYMENT SETTINGS
# ============================================================================

# Domains - CHANGE THESE to your actual domains
FRONTEND_DOMAIN=example.com
BACKEND_DOMAIN=api.example.com

# Ports exposed to host machine from Docker containers
FRONTEND_PORT=4000
BACKEND_PORT=9000

# Gunicorn workers (default: 4)
# Recommended formula: (2 x CPU cores) + 1
# Example: 4-core server = (2 x 4) + 1 = 9 workers
GUNICORN_WORKERS=4

# ============================================================================
# BACKEND SETTINGS
# ============================================================================

# Django Secret Key - CHANGE THIS to a long random string
SECRET_KEY=your-secret-key-here-change-this-to-a-long-random-string

# Debug mode - MUST be False in production
DEBUG=False

# Allowed hosts (comma-separated, no spaces)
ALLOWED_HOSTS=api.example.com,localhost

# CORS allowed origins (comma-separated, no spaces)
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# CSRF trusted origins (comma-separated, no spaces)
CSRF_TRUSTED_ORIGINS=https://api.example.com,localhost

# Frontend URL - used for links in emails
FRONTEND_URL=https://example.com

# ============================================================================
# DATABASE SETTINGS
# ============================================================================

POSTGRES_DB=urlinks_prod
POSTGRES_USER=urlinks_user
POSTGRES_PASSWORD=change-this-to-secure-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================================================
# EMAIL SETTINGS (SMTP)
# ============================================================================

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=your-smtp-password

# ============================================================================
# FRONTEND SETTINGS
# ============================================================================

# Frontend API URL - CHANGE THIS to your backend domain
# This is embedded into the frontend JavaScript at build time
VITE_BE_URL=https://api.example.com
