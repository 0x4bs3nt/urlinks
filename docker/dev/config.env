# Development Configuration
# Copy this file to .env before running docker compose
# All configuration is in this single file

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Ports exposed to host machine from Docker containers
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT_EXPOSED=5432

# Gunicorn workers (default: 2 for development)
# Lower value for development to save resources
GUNICORN_WORKERS=2

# ============================================================================
# BACKEND SETTINGS
# ============================================================================

# Django Secret Key - for development only
SECRET_KEY=django-insecure-docker-dev-key-change-in-production

# Debug mode - True for development
DEBUG=True

# Allowed hosts (comma-separated, no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# CORS allowed origins (comma-separated, no spaces)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# CSRF trusted origins (comma-separated, no spaces)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Frontend URL - used for links in emails, among other things
FRONTEND_URL=http://localhost:3000

# ============================================================================
# DATABASE SETTINGS
# ============================================================================

POSTGRES_DB=urlinks
POSTGRES_USER=urlinks_user
POSTGRES_PASSWORD=urlinks_pass
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================================================
# FRONTEND SETTINGS
# ============================================================================

# Frontend API URL - for development
# This is embedded into the frontend JavaScript at build time
VITE_BE_URL=http://127.0.0.1:8000
