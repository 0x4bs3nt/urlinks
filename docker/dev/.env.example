# Docker Compose environment variables
# These are used for variable substitution in docker-compose.yml

# ports
FRONTEND_PORT=3000
BACKEND_PORT=8000

# db
POSTGRES_DB=freetree
POSTGRES_USER=freetreeuser
POSTGRES_PASSWORD=freetreepass

# backend
SECRET_KEY=django-insecure-dev-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# r2
R2_ENDPOINT_URL=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=

# email
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=
EMAIL_USE_TLS=

# vite
VITE_BE_URL=http://localhost:8000
